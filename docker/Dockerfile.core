FROM python:3.12-slim AS runtime
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /app
RUN useradd -m appuser
COPY services/requirements-core.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt
COPY services /app/services
COPY services/lite_pipeline /app/services/lite_pipeline
USER appuser
CMD ["python", "-m", "services.lite_pipeline.main", "crawl:single", "--url", "https://example.com"]
