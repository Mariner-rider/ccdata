FROM python:3.12-slim AS runtime
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /app
RUN useradd -m appuser
COPY pyproject.toml README.md /app/
COPY services /app/services
RUN pip install --no-cache-dir -e ".[webclaw,postgres,redis]" fastapi==0.115.12 uvicorn==0.34.0
USER appuser
CMD ["uvicorn", "services.lite_pipeline.api:app", "--host", "0.0.0.0", "--port", "8000"]
