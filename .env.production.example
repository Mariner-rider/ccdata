# CollegeCue production environment template.
# Copy to .env, fill every value, and never commit real secrets.

# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=replace_with_postgres_password_generated_by_openssl
MINIO_ROOT_PASSWORD=replace_with_minio_password_generated_by_openssl
SERVICE_API_KEY=replace_with_service_api_key_generated_by_openssl
AIRFLOW_ADMIN_PASSWORD=replace_with_airflow_password_generated_by_openssl

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace_with_generated_fernet_key

MINIO_ROOT_USER=minio
AIRFLOW_ADMIN_USERNAME=airflow_user
AIRFLOW_ADMIN_EMAIL=ops@example.com
PUBLIC_CORS_ORIGINS=https://collegecue.com,https://www.collegecue.com

DATABASE_URL=postgresql://crawler:${POSTGRES_PASSWORD}@postgres:5432/crawler
POSTGRES_DSN=postgresql://crawler:${POSTGRES_PASSWORD}@postgres:5432/crawler
REDIS_URL=redis://redis:6379/0
QUEUE_BACKEND=redis
WEBCLAW_ENABLED=false
DEBUG_RAW_HTML=false
RAW_HTML_RETENTION_DAYS=30
CRAWL_RATE_LIMIT_SECONDS=2.0
API_RATE_LIMIT_PER_MINUTE=300
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=raw-html
