# REQUIRED — change before running. Never commit real values.
POSTGRES_PASSWORD=changeme_use_a_strong_password
MINIO_ROOT_PASSWORD=changeme_use_a_strong_password
AIRFLOW_ADMIN_PASSWORD=changeme_use_a_strong_password
SERVICE_API_KEY=changeme_generate_with_openssl_rand_hex_32
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=changeme_generate_with_cryptography_fernet

MINIO_ROOT_USER=minio
DATABASE_URL=postgresql://<user>:${POSTGRES_PASSWORD}@<host>:5432/<db>
POSTGRES_DSN=postgresql://<user>:${POSTGRES_PASSWORD}@<host>:5432/<db>
REDIS_URL=redis://<host>:6379/0
WEBCLAW_ENABLED=true
WEBCLAW_BASE_URL=https://webclaw.internal
WEBCLAW_TIMEOUT_SECONDS=30
DEBUG_RAW_HTML=false
RAW_HTML_RETENTION_DAYS=30
CRAWL_RATE_LIMIT_SECONDS=2.0
API_RATE_LIMIT_PER_MINUTE=300
PUBLIC_CORS_ORIGINS=https://collegecue.com,https://www.collegecue.com
